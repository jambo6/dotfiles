# Some environment variables
export ZSH=$HOME/.oh-my-zsh
export TERM="xterm-256color"

# OH MY ZSH ---------
ZSH_THEME="refined"
plugins=(
	vi-mode
	history-substring-search
	z
)
source $ZSH/oh-my-zsh.sh
# Changes prompt
DEFAULT_USER=username

# Neovim --------------
alias vim="nvim"

# TMUX ----------------
alias srctmux="tmux source-file ~/.tmux.conf"
alias tconf="vim ~/.tmux.conf"
alias tls="echo ; tmux ls; echo;"
tnew() { tmux new -s $1 ; }
tatt() { tmux a -t $1 ; }
tkill() { tmux kill-session -t $1 ; }
trename() { tmux rename-window $1 ;}

# rc files
alias zshrc="vim ~/.zshrc"
alias srczsh="source ~/.zshrc"
alias initvim="vim ~/.config/nvim/init.vim"
alias dotfiles="cd ~/dotfiles"
# Some useful stuff
alias clc="clear"
alias del="trash"
alias ohmyzsh="mate ~/.oh-my-zsh"
alias checkpython="ps -ef | grep python"
alias killpython="pkill -9 python"
# Conda
alias activate="conda activate ./env"
alias base="conda activate base"

# Functions
# After mkdir, cd into it
mkcd() {
	mkdir -p "$*"
	cd "$*"
}

# Git
# ----------------------
# Git Aliases
# ----------------------
alias ga='git add'
alias gaa='git add .'
alias gaaa='git add --all'
alias gau='git add --update'
alias gr~='git reset HEAD~'
alias gb='git branch'
alias gbd='git branch --delete '
alias gba='git branch -a'
alias gc='git commit'
alias gcnv='git commit --no-verify'
alias gcm='git commit --message'
alias gcmnv='git commit --no-verify --message'
alias gcf='git commit --fixup'
alias gco='git checkout'
# alias gcob='git checkout -b'
alias gcob='git branch | fzf | xargs git checkout'
alias gcom='git checkout master'
alias gcos='git checkout staging'
alias gcod='git checkout develop'
alias gd='git diff'
alias gda='git diff HEAD'
alias gi='git init'
alias glg='git log --graph --oneline --decorate --all'
alias gld='git log --pretty=format:"%h %ad %s" --date=short --all'
alias glp='git log --pretty=oneline'
alias gm='git merge --no-ff'
alias gma='git merge --abort'
alias gmc='git merge --continue'
alias gp='git pull'
alias gpr='git pull --rebase'
alias gr='git rebase'
alias gri='git rebase -i'
alias gs='git status'
alias gss='git status --short'
alias gst='git stash'
alias gsta='git stash apply'
alias gstd='git stash drop'
alias gstl='git stash list'
alias gstp='git stash pop'
alias gsts='git stash save'

# ----------------------
# Git Functions
# ----------------------
# Git log find by commit message
function glf() { git log --all --grep="$1"; }
